{
  "name": "@wonderloop/api-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 && prettier --ignore-path ../../.prettierignore --check .",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json",
    "gen:types": "supabase gen types typescript --local > src/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10"
  },
  "devDependencies": {
    "@wonderloop/config": "workspace:*"
  }
}
